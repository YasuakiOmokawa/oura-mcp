# Optional: alternative to `npx oura-mcp configure`. If using env vars, both must be set together.
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Optional: callback port for OAuth flow (default: 54321). Must match the redirect URI registered with Oura.
OURA_CALLBACK_PORT=54321

# Optional: log level (debug | info | warn | error). Default: info. All logs go to stderr.
OURA_LOG_LEVEL=info

# Optional: override OpenAPI schema URL for fetch:schema. Default: https://cloud.ouraring.com/v2/static/json/openapi-1.29.json
# OURA_OPENAPI_URL=
